# Salesforce internal Anthropic token (required)
ANTHROPIC_AUTH_TOKEN=your_salesforce_auth_token_here

# Salesforce Bedrock proxy endpoint (required)
ANTHROPIC_BASE_URL=https://proxy.internal.salesforce.com

# Google Custom Search credentials (required for web search)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Optional overrides
CLAUDE_MODEL=claude-opus-4-7
USE_THINKING=0
