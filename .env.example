# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Salesforce internal token (mutually exclusive with ANTHROPIC_API_KEY)
ANTHROPIC_AUTH_TOKEN=your_salesforce_auth_token_here

# Standard Anthropic API key (use this outside Salesforce)
# ANTHROPIC_API_KEY=sk-ant-...

# Salesforce Bedrock proxy endpoint (only required with ANTHROPIC_AUTH_TOKEN)
ANTHROPIC_BASE_URL=https://proxy.internal.salesforce.com

# ── Web Search ────────────────────────────────────────────────────────────────
# Required — the Researcher agent uses Tavily to find up-to-date MuleSoft docs.
# Get a free key at https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Optional overrides ────────────────────────────────────────────────────────
# Default: claude-opus-4-7
# CLAUDE_MODEL=claude-opus-4-7

# Set to 1 to enable adaptive thinking (Opus 4.7 recommended)
# USE_THINKING=0
